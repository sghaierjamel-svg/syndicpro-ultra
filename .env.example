# ── Scanner Syndic — Variables d'environnement ──────────────────────────────

# RNE Auth (optionnel — pour accéder aux données complètes du registre)
RNE_USERNAME=votre_email@example.com
RNE_PASSWORD=votre_mot_de_passe

# Agent Email — Resend (recommandé, gratuit jusqu'à 3000 emails/mois)
# Créer un compte sur https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=contact@syndicpro.tn
EMAIL_FROM_NAME=SyndicPro

# Agent Email — SMTP (alternative à Resend, ex: Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre_email@gmail.com
# SMTP_PASS=votre_mot_de_passe_app

# Délai entre chaque email (secondes) — évite le spam
EMAIL_DELAY_SEC=3

# Clé API (optionnel — sécurise les endpoints de modification)
API_KEY=

# Base de données
DB_PATH=data/data.db
